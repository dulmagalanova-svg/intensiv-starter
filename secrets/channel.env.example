# ───────────────────────────────────────────────────────────────────
# channel.env — настройки подключения агента к Telegram
#
# КАК ПОЛЬЗОВАТЬСЯ:
#   1. Скопируй этот файл рядом и убери «.example» из имени:
#         secrets/channel.env.example  →  secrets/channel.env
#   2. Впиши свой токен бота и свой Telegram ID (ниже подсказано как).
#   3. Сохрани. Файл channel.env НИКУДА не выкладывается — он только у тебя.
#
# В этом файле НЕТ настоящих секретов — только заготовки. Свои значения
# вписываешь сам в channel.env (не в .example).
# ───────────────────────────────────────────────────────────────────

# ─── Telegram-бот ───────────────────────────────────────────────────
# Токен из @BotFather (Шаг 2). Выглядит так: 8976066018:AAH...длинная-строка
TELEGRAM_BOT_TOKEN=вставьте_сюда_токен_от_BotFather

# Номер (id) твоего бота — это ЦИФРЫ В НАЧАЛЕ токена, до двоеточия.
# Пример: если токен 8976066018:AAH... — сюда впиши 8976066018
TELEGRAM_EXPECTED_BOT_ID=вставьте_сюда_цифры_до_двоеточия

# ─── Кому бот отвечает (только тебе) ────────────────────────────────
# Твой личный Telegram ID (НЕ номер телефона, не @username, а число).
# Как узнать: в Telegram напиши боту @userinfobot — он пришлёт твой Id.
# Впиши это число в обе строки ниже.
TELEGRAM_ALLOWED_USER_IDS=вставьте_сюда_ваш_telegram_id
TELEGRAM_ALLOWED_CHAT_IDS=вставьте_сюда_ваш_telegram_id

# ─── Где лежит агент (пути) ─────────────────────────────────────────
# Папка с личностью агента (где лежит CLAUDE.md). Обычно менять НЕ нужно —
# по умолчанию это корень склонированного репозитория.
# Если правишь — укажи полный путь до папки intensiv-starter.
TELEGRAM_WORKSPACE_ROOT=.

# Короткое имя агента (латиницей, без пробелов). Например: assistant
AGENT_ID=assistant

# ─── Служебная папка состояния (создаётся автоматически) ────────────
# Сюда плагин складывает рабочие файлы. Обычно менять НЕ нужно.
TELEGRAM_STATE_DIR=./state/telegram

# ─── Внутренний веб-порт (для расширений, можно не трогать) ──────────
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8099

# ─── Память (второй мозг) — задел под Урок 2 ────────────────────────
# Пока выключено. Включим, когда будем настраивать память агента.
TELEGRAM_MEMORY_ENABLED=false
# TELEGRAM_MEMORY_WORKSPACE=.
# TELEGRAM_MEMORY_AGENT_LABEL={{ИМЯ_АГЕНТА}}
# TELEGRAM_MEMORY_SOURCE_TAG=tg

# ─── Голосовые сообщения (необязательно) ────────────────────────────
# Чтобы агент понимал голосовые — нужен бесплатный ключ Groq (console.groq.com).
# Если не нужно — оставь пусто, текстом всё работает без ключа.
# GROQ_API_KEY=вставьте_сюда_ключ_groq_если_нужны_голосовые
